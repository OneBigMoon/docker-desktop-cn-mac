{
  "name": "docker-desktop-cn-patcher",
  "displayName": "Docker Desktop CN Patcher",
  "version": "0.1.0",
  "target": "Docker Desktop for Mac",
  "testedVersions": [
    "4.69.0"
  ],
  "compatibleVersionRules": [
    {
      "range": "4.x",
      "level": "best-effort",
      "notes": "Uses runtime injection and guarded string replacements. Newer Docker Desktop releases may need extra dictionary entries."
    }
  ],
  "files": {
    "uiPatch": "assets/cn-patch.js"
  },
  "nativeReplacements": [
    {
      "fileHint": "build/entry-cli.main.js",
      "replacements": [
        {
          "from": "label:\"变基\"",
          "to": "label:\"编辑\""
        },
        {
          "from": "label:'变基'",
          "to": "label:'编辑'"
        }
      ]
    }
  ]
}
